{
  "name": "go-automate-tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/go-automate-tui",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepare": "effect-language-service patch"
  },
  "dependencies": {
    "@opentui/core": "^0.4.0",
    "effect": "^4.0.0-beta.93",
    "fuse.js": "^7.3.0"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.4",
    "@types/bun": "^1.3.13",
    "prettier": "^3.5.3",
    "typescript": "^6.0.3"
  }
}

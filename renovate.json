{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    "group:recommended"
  ],
  "dependencyDashboard": true,
  "labels": [
    "dependencies"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Group documentation site (Astro/Starlight) dependencies.",
      "groupName": "docs site",
      "matchFileNames": ["docs/**"]
    },
    {
      "description": "Group GitHub Actions.",
      "groupName": "github actions",
      "matchManagers": ["github-actions"]
    }
  ]
}
